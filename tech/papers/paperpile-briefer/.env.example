# Paperpileのエクスポートファイルを指定します。
# Paperpile: Settings > Data and files > Export でJSONまたはBibTeXを書き出してください。
PAPERPILE_EXPORT_PATH=/path/to/paperpile-export.json

# 任意: export内のPDFパスが相対パスの場合の基準ディレクトリ
# PAPERPILE_PDF_BASE_DIR=/path/to/Paperpile

# 任意: brief生成に渡すPDF抽出テキストの最大文字数
PDF_TEXT_MAX_CHARS=60000

# 任意: 実行前にPaperpile exportを最新化するスクリプト
# PAPERPILE_SYNC_SCRIPT=/home/hiroki/Obsidian/scripts/sync_papers.sh

# 生成物の保存先
OUTPUT_DIR=./briefs
RAW_DIR=./raw
CHAT_DIR=./chat
STATE_DIR=./state
LOG_DIR=./logs

# 任意: MarkdownをObsidianにもコピーする
EXPORT_TO_OBSIDIAN=false
OBSIDIAN_EXPORT_DIR=/home/hiroki/Obsidian/intake/paperpile-briefs

# 任意: モバイル通知
# 1. ntfy mobile appを使う場合
# NTFY_TOPIC=your-private-topic
# NTFY_SERVER=https://ntfy.sh
#
# 2. 任意のwebhookへJSON POSTする場合
# MOBILE_WEBHOOK_URL=https://example.com/webhook
#
# 3. Gmail通知する場合
# GMAIL_ADDRESS=your@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# NOTIFY_EMAIL_TO=your@gmail.com
#
# GMAIL_*だけ別ファイルにある場合はrun_daily.shのNOTIFY_ENV_FILEで指定できます。
# デフォルトでは ../hf-paper-tracker/.env のGMAIL_*だけを通知スクリプトが読みます。

# 任意: 生成後にgit commit/pushする（systemdではfalse推奨）
PUSH_TO_GIT=false
